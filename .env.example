# Backend API (used by Streamlit)
API_BASE_URL=http://localhost:8000

# LLM API (used by the FastAPI chat endpoint)
API_URL=https://your-llm-api-endpoint/v1/chat/completions
API_KEY=your-api-key-here
LLM_MODEL=gpt-5-mini

# Optional: Redis cache (reduce LLM cost, speed up repeated queries)
# REDIS_URL=redis://localhost:6379/0
# CACHE_ENABLED=true
# CACHE_TTL_EMBEDDING=86400
# CACHE_TTL_RETRIEVAL=3600
# CACHE_TTL_RESPONSE=3600

# Optional: override paths / embedding
# LOG_FILE_PATH=logs/app.log
# FAISS_INDEX_PATH=data/faiss_index
# EMBEDDING_MODEL_PATH=microsoft/mpnet-base
# TEXT_CHUNK_SIZE=300
